# Copy to .env and fill in values

# Database
POSTGRES_PASSWORD=change-me
POSTGRES_USER=news
POSTGRES_DB=news

# Optional: override DATABASE_URL if not using default
# DATABASE_URL=postgresql://news:password@localhost:5432/news

# Flask
SECRET_KEY=change-me-in-production

# LLM API keys (at least one required for rewriting)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Embeddings (required for article clustering)
# Default: local (sentence-transformers, no key needed)
# Set embeddings.provider: openai in config/app.yaml to use OpenAI; then OPENAI_API_KEY is required
