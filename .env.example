# Optional for development: docker-compose up works without this file.
# Copy to .env to override defaults or for production.

# Database (dev defaults used when .env is absent)
POSTGRES_PASSWORD=devpassword
POSTGRES_USER=news
POSTGRES_DB=news

# Flask (dev default used when .env is absent)
SECRET_KEY=dev-secret-key-change-in-production

# Optional: override DATABASE_URL if not using default
# DATABASE_URL=postgresql://news:password@localhost:5432/news

# Ollama (optional override; default in Docker is http://ollama:11434)
# OLLAMA_HOST=http://ollama:11434
